{
  "appId": "com.timertrink.app",
  "appName": "Timer Trink",
  "webDir": "www",
  "bundledWebRuntime": false,

  "server": {
    "androidScheme": "https"
  },

  "android": {
    "allowMixedContent": true
  },

  "plugins": {
    "LocalNotifications": {
      "smallIcon": "ic_stat_icon_config_sample",
      "iconColor": "#ffffff",
      "sound": "beep"
    },
    "SplashScreen": {
      "launchShowDuration": 2000,
      "backgroundColor": "#000000",
      "showSpinner": false
    }
  }
}
